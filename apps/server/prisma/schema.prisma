generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
  CANCELED
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELED
}

model User {
  id            String          @id @default(cuid())
  email         String          @unique @db.VarChar(191)
  passwordHash  String          @db.VarChar(255)
  vpnUuid       String?         @unique @db.VarChar(36)
  vpnUpdatedAt  DateTime?
  xuiEmail      String?         @unique @db.VarChar(191)
  xuiInboundId  Int?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  paymentIntents PaymentIntent[]
  subscription  Subscription?
}

model Plan {
  id             String          @id @default(cuid())
  code           String          @unique @db.VarChar(64)
  name           String          @db.VarChar(120)
  description    String?         @db.VarChar(255)
  priceRub       Int
  durationDays   Int
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  paymentIntents PaymentIntent[]
  subscriptions  Subscription[]
  promoCodes    PromoCode[]
}

model PaymentIntent {
  id           String        @id @default(cuid())
  userId       String
  planId       String
  amountRub    Int
  provider     String        @default("yookassa") @db.VarChar(32)
  status       PaymentStatus @default(PENDING)
  externalId   String?       @unique @db.VarChar(191)
  sbpDeepLink  String?       @db.Text
  sbpQrDataUrl String?       @db.LongText
  paidAt       DateTime?
  expiresAt    DateTime
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([userId, status])
  @@index([planId])
  @@index([createdAt])
}

model Subscription {
  id              String             @id @default(cuid())
  userId          String             @unique
  planId          String
  paymentIntentId String?            @db.VarChar(191)
  status          SubscriptionStatus @default(ACTIVE)
  startsAt        DateTime           @default(now())
  endsAt          DateTime
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([status, endsAt])
}

enum PromoCodeType {
  ONETIME
  PERMANENT
}

model PromoCode {
  id           String       @id @default(cuid())
  code         String       @unique @db.VarChar(64)
  discountPercent Int
  maxUses      Int?
  usedCount    Int          @default(0)
  type         PromoCodeType @default(ONETIME)
  planId       String
  isActive     Boolean      @default(true)
  expiresAt    DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  plan   Plan             @relation(fields: [planId], references: [id], onDelete: Restrict)
  usages PromoCodeUsage[] @relation("PromoCodeUsages")

  @@index([code])
  @@index([isActive])
}

model PromoCodeUsage {
  id         String   @id @default(cuid())
  promoCodeId String
  userId     String
  usedAt     DateTime @default(now())

  promoCode PromoCode @relation("PromoCodeUsages", fields: [promoCodeId], references: [id], onDelete: Cascade)

  @@unique([promoCodeId, userId])
  @@index([userId])
}
